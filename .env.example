# Database
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Auth (Clerk)
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."

# Payments (Mercado Pago)
MERCADO_PAGO_ACCESS_TOKEN="APP_USR-..."
MERCADO_PAGO_WEBHOOK_SECRET="your-webhook-secret"
# Registrar webhook no painel MP: https://SEU_DOMINIO/webhooks/mercadopago (ex: https://api-rateio.ckao.in/webhooks/mercadopago)
# DEBUG_WEBHOOK=true  # opcional: loga body completo do webhook

# Geo (Google Maps Platform)
# Recomendado: restringir por IP (backend) e setar budgets/quotas no Google Cloud Console.
# Habilitar APIs: Places API e Geocoding API.
GOOGLE_MAPS_API_KEY="AIza..."

# Geo (fallback Nominatim - usado apenas se GOOGLE_MAPS_API_KEY não estiver setada)
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"
NOMINATIM_USER_AGENT="rateio-api/1.0 (contact: support@rateio.ckao.in)"

# Pricing
BASE_FEE_CENTS=100
USD_BRL_RATE=5.0
AI_COST_MARGIN=1.5